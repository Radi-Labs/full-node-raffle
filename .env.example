# Copy this to .env and fill in your values.
# Never commit .env to version control.

# --- Webapp ---
# Secret key for Flask session signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change-me-to-a-random-string

# Path to the raffle state JSON file (default: raffle_state.json in CWD)
RAFFLE_STATE=raffle_state.json

# Operator dashboard password (HTTP Basic Auth). Leave blank to disable auth (local-only use).
RAFFLE_PASSWORD=

# Port for the Flask webapp (default: 5000)
PORT=5000

# --- Bitcoin Core RPC (optional, use instead of mempool.space for block hashes) ---
# Format: http://user:password@host:port
# BITCOIN_RPC_URL=http://rpcuser:rpcpass@127.0.0.1:8332

# --- Nostr ---
# Your organizer nsec (secret key). Only needed for the publish step.
# Keep this out of .env if you prefer to supply it interactively via the CLI/dashboard.
# NOSTR_NSEC=nsec1...

# --- Sybil protection ---
# Max entries allowed from a single IP address per round (default: 1)
MAX_ENTRIES_PER_IP=1
